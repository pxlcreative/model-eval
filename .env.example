# Copy this file to .env and fill in values before running locally.

# PostgreSQL connection string.
# Local dev: points to localhost (or the Docker-exposed port).
# In Docker Compose the app and migrate services use the internal URL:
#   postgresql://postgres:postgres@db:5432/portfolio_evaluator
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_evaluator

# Shared secret sent in the x-api-key header for all /api/* requests.
# Generate a strong value for production: openssl rand -hex 32
API_KEY=change-me-before-deploying

# Next.js environment. Use "development" locally, "production" in Docker.
NODE_ENV=development

# Reserved for future auth (NextAuth.js). Not currently used.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
