generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RuleType {
  HARD_STOP
  WARNING
}

enum RuleKind {
  KEYWORD
  KEYWORD_WEIGHT_THRESHOLD
}

enum MatchMode {
  ANY
  ALL
}

enum WeightOp {
  GT
  GTE
  LT
  LTE
}

enum EvalSource {
  UI
  API
}

enum EvalResult {
  PASS
  WARN
  FAIL
}

model Rule {
  id          String    @id @default(uuid())
  name        String    @unique
  type        RuleType
  rule_kind   RuleKind
  keywords    String[]
  match_mode  MatchMode @default(ANY)
  weight_op   WeightOp?
  weight_pct  Decimal?
  description String?
  active      Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
}

model EvaluationLog {
  id              String     @id @default(uuid())
  source          EvalSource
  portfolio_name  String?
  positions       Json
  result          EvalResult
  triggered_rules Json
  evaluated_at    DateTime   @default(now())
}
